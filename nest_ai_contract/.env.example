# Server Configuration
# Port for the NestJS API server (default: 4001)
PORT=4001

# Database Configuration
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_contract

# Redis (for BullMQ ingest queue)
REDIS_URL=redis://localhost:6379

UPLOAD_DIR=./data/uploads
API_BASE_URL=http://localhost:4001/api/v1


# AWS Configuration
# AWS Region (e.g., us-east-1, us-west-2, ap-southeast-1)
AWS_REGION=ap-southeast-1
# AWS Credentials
# Get these from AWS IAM Console or AWS CLI
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS Bedrock Model Configuration
# Embeddings model
AWS_BEDROCK_EMBEDDINGS_MODEL=cohere.embed-multilingual-v3
# Chat model (default: Claude 3 Haiku - cost-effective)
# Options:
#   - anthropic.claude-3-haiku-20240307-v1:0 (cheapest, ~$0.25/$1.25 per 1M tokens)
#   - anthropic.claude-3-sonnet-20240229-v1:0 (balanced, ~$3/$15 per 1M tokens)
#   - anthropic.claude-3-opus-20240229-v1:0 (best quality, ~$15/$75 per 1M tokens)
#   - amazon.titan-text-lite-v1 (Amazon's model, ~$0.30/$0.40 per 1M tokens)
AWS_BEDROCK_CHAT_MODEL=anthropic.claude-3-haiku-20240307-v1:0
# File Storage Configuration
# If using local disk, UPLOAD_DIR is used by legacy code paths.
# For S3, set AWS_S3_BUCKET (and optionally AWS_REGION, AWS_S3_PREFIX) and UPLOAD_DIR is ignored by new S3 logic.
AWS_S3_BUCKET=d-s3-contract
# Optional prefix inside the bucket, e.g. contracts/
AWS_S3_PREFIX=contracts/

# Chunking Configuration
# Maximum characters per chunk (default: 3500, ~700-900 tokens)
CHUNK_MAX_CHARS=3500

# Overlap between chunks in characters (default: 350)
CHUNK_OVERLAP_CHARS=350

# Chunking version for hash generation (change to invalidate existing hashes)
CHUNKING_VERSION=v1

# Embedding Configuration
# Batch size for embedding API calls (default: 16)
EMBED_BATCH_SIZE=16

# RAG Configuration
# Number of top chunks to retrieve for RAG (default: 8)
RAG_TOP_K=8

# Custom system prompt for RAG chat (optional)
# If not set, uses default prompt
# RAG_SYSTEM_PROMPT=You are a contract analysis assistant...

# Chat Configuration
# Maximum tokens for chat responses (default: 700)
CHAT_MAX_TOKENS=700

# Temperature for chat responses (default: 0.2, lower = more deterministic)
CHAT_TEMPERATURE=0.2
